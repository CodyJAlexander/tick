{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "tick",
  "version": "0.1.0",
  "identifier": "com.calexander.tick",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Tick",
        "width": 900,
        "height": 600,
        "visible": false,
        "decorations": true
      },
      {
        "label": "popup",
        "title": "",
        "width": 360,
        "height": 120,
        "visible": false,
        "decorations": false,
        "alwaysOnTop": true,
        "resizable": false,
        "center": true
      }
    ],
    "trayIcon": {
      "iconPath": "icons/tray-default.png",
      "iconAsTemplate": true
    },
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
